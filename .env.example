# -----------------------------------------------------------------------
# Eaux de Marseille - Home Assistant integration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# -----------------------------------------------------------------------

# Required — your portal credentials (espaceclients.eauxdemarseille.fr)
EDM_LOGIN=your.email@example.com
EDM_PASSWORD=your_password

# Required — your contract number (visible on bills and in the portal URL)
EDM_CONTRACT_ID=1234567

# Optional — HTTP request timeout in seconds (default: 15)
# EDM_TIMEOUT=15

# Optional — logging level: DEBUG, INFO, WARNING, ERROR (default: WARNING)
# EDM_LOG_LEVEL=WARNING

# Required for import_history.py only
# HA_URL=http://192.168.1.x:8123
# HA_TOKEN=your_long_lived_access_token
